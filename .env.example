# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Shopify Admin API ────────────────────────────────────────────────────────
# 1. Shopify Admin → Settings → Apps and sales channels → Develop apps
# 2. Create app "Canyon Exotics OS", configure Admin API scopes:
#    read_orders, read_products, read_customers, read_inventory (read-only first slice)
# 3. Install on your store, copy the Admin API access token (starts with shpat_).
# 4. SHOPIFY_SHOP_DOMAIN is the *.myshopify.com subdomain, not your custom domain.
SHOPIFY_SHOP_DOMAIN="canyon-exotics.myshopify.com"
SHOPIFY_ADMIN_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SHOPIFY_API_VERSION="2025-01"

# Backend dev port — Vite proxies /api → here (see vite.config.ts).
API_PORT="8787"

# ── Plaid (bank feed for reconciliation) ─────────────────────────────────────
# Sign up at https://dashboard.plaid.com/signup. Get client_id + sandbox secret.
# Without these, /api/finance/bank-feed returns a fixture so the UI keeps working.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"             # sandbox | development | production
# After the operator completes a Link flow once, paste the long-lived access
# token here so the server can fetch transactions. In production, persist this
# per-user in a real DB.
PLAID_ACCESS_TOKEN=""
# Plaid webhook verification.
# Production uses JWT-based verification automatically (Plaid signs every
# webhook with ES256; the server fetches the verifying public key from
# /webhook_verification_key/get and caches by `kid`). PLAID_WEBHOOK_SECRET
# is only used as a fallback for sandbox testing where the JWT path isn't
# convenient. Set NODE_ENV=production to refuse webhooks without a JWT.
PLAID_WEBHOOK_SECRET=""

# ── Stripe (1099-K auto-pull + payout reconciliation) ────────────────────────
# Use a restricted key with read access to: balance, balance_transactions,
# payouts, charges. Without it, the 1099-K Sync button reports unavailable
# and /finances/payouts shows mock data.
STRIPE_SECRET_KEY=""
